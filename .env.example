APP_NAME=跨境电商物流 AI 优化助手
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/logistics_ai
REDIS_URL=redis://localhost:6379/0
DEFAULT_CURRENCY=USD

# mock：只使用本地模拟承运商；real：只使用真实承运商；mixed：两者同时启用。
CARRIER_MODE=mock
CARRIER_TIMEOUT_SECONDS=8
CARRIER_RETRY_COUNT=2
TASK_STATUS_PERSISTENCE_ENABLED=false

# 真实 API Key 只放环境变量或部署平台密钥，不提交真实值。
SHIPPO_API_KEY=
DHL_API_KEY=
FEDEX_API_KEY=
UPS_API_KEY=
AFTERSHIP_API_KEY=

# 后续对接模型服务和 RAG/LLM 服务时启用。
MODEL_SERVICE_URL=
LLM_SERVICE_URL=
